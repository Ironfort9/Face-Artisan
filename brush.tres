[gd_resource type="Resource" script_class="Brush" format=3 uid="uid://b31y4v3cxg08l"]

[sub_resource type="GDScript" id="GDScript_pfxit"]
script/source = "extends Resource
class_name Brush

@export var brush_name: String;
@export var brush_texture: Texture2D;

func Apply(current_color: Color, brush_color: Color, tint_color: Color):
	return current_color.lerp(tint_color, brush_color.r)
"

[resource]
script = SubResource("GDScript_pfxit")
